include: site.def?

macros:
    commit_hash: 6c5e707c6b5339359a9a9e215c5e66d6d802fd7a # 25.11 - 260210


subcode: basic_frame
    let
        nixpkgs = fetchTarball "https://github.com/NixOS/nixpkgs/archive/$(commit_hash).tar.gz";
        $call set_pkgs

    in
    pkgs.mkShell {
        packages = with pkgs; [
            $(pkgs)
        ];

        shellHook = ''
            $call main
        '';
    }

subcode: set_pkgs
    pkgs = import nixpkgs { config = {allowUnfree = true;}; overlays = []; };

#---------------------------------------- 

page: claude.nix, basic_frame
    output_dir: ./nix
    pkgs:

    $call set_PS1, claude
    alias claude='$HOME/.local/share/claude/versions/2.1.39'

page: opencode.nix, basic_frame
    output_dir: ./nix
    pkgs:

    $call set_PS1, opencode
    alias opencode='$HOME/.opencode/bin/opencode'

page: win32.nix, basic_frame
    output_dir: ./nix
    pkgs: pkgsCross.mingwW64.stdenv.cc

    $call set_PS1, win32
    export WCC=x86_64-w64-mingw32-gcc
    alias wcc=$WCC

page: doc.nix, basic_frame
    output_dir: ./nix
    pkgs: (ruby.withPackages (ps: with ps; [ asciidoctor rbs racc ]))

    $call set_PS1, doc

#---------------------------------------- 
page: python.nix, basic_frame
    output_dir: ./nix
    pkgs: python3

    $call set_PS1, python
    $call @python_site

page: npm.nix, basic_frame
    output_dir: ./nix
    pkgs: nodejs
    # puppeteer-cli atk libxkbcommon libgbm 

    $(if:0)
        GLIBC=/nix/store/wb6rhpznjfczwlwx23zmdrrw74bayxw4-glibc-2.42-47
        ATK=/nix/store/57p0pw4smcb0zpz7wbczrys3nzdsjg88-at-spi2-core-2.58.2
        XKB=/nix/store/zmqws0ch2636qgg6f62ha2wbdaxw9qdc-libxkbcommon-1.11.0
        GBM=/nix/store/3mvmm3kqf2as7h9m59wafdkxfvyhshlf-mesa-libgbm-25.1.0
    export LD_LIBRARY_PATH=$ATK/lib:$XKB/lib:$GBM/lib

#---------------------------------------- 

subcode: set_PS1(name)
    export PS1='\n\[\033[1;32m\][$(name):\w]\$\[\033[0m\] '
