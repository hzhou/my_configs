page: sync_vim.sh
    # skiprun: 1
    cp -v out/_vimrc $HOME/.vimrc

    if [ -d "$MYDEFSRC" ]; then
        mkdir -p $HOME/.vim/syntax
        cp -v out/_vim/filetype.vim    $HOME/.vim/
        cp -v $MYDEFSRC/docs/mydef.vim $HOME/.vim/syntax/
    fi

#---------------------------------------- 
page: _vimrc.none
    skiprun: 1
    $call basic
    $call shortcut

subcode: basic
    :set background=dark
    :set laststatus=2
    :set ruler
    :set showmode
    :set autoindent
    :set shiftwidth=4
    :set expandtab
    :set shiftround
    :set hlsearch
    :syntax on

    :set pastetoggle=<F12>
    :nmap <F5> :!mydef_run %<CR>
    :nmap <F9> :q!<CR>
    :nmap <F10> :make install<CR>

subcode: shortcut
    :abbr #i #include
    :abbr #d #define
    :abbr ## #----------------------------------------
    :abbr 2# ##
    :abbr 3# ###
    :abbr 4# ####
    :abbr 5# #####
    :abbr 6# ###### 

page: filetype.vim
    output_dir: _vim
    skiprun: 1

    augroup filetypedetect
        au BufNewFile,BufRead *.def setf mydef
    augroup END

